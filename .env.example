# Email de la cuenta de servicio de Google (termina en .iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Clave privada de la cuenta de servicio (el contenido del JSON descargado, campo "private_key")
# En Vercel: pegala tal cual, con los \n incluidos como texto.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ID de la planilla de Google Sheets (se ve en la URL: /d/ESTE-ID/edit)
GOOGLE_SHEET_ID=

# ID de la carpeta de Google Drive donde se guardan las facturas subidas
GOOGLE_DRIVE_FOLDER_ID=
